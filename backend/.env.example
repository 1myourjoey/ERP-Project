# === Database ===
DATABASE_URL=sqlite:///./erp.db

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Authentication ===
# VON_AUTH_DISABLED=false   # true로 설정 시 인증 비활성화 (개발 전용)
VON_SECRET_KEY=change-this-to-a-random-64-char-string
VON_ACCESS_TOKEN_EXPIRE_MINUTES=60
VON_REFRESH_TOKEN_EXPIRE_DAYS=7
VON_PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# === Google OAuth ===
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# === LLM (OpenAI) ===
# OPENAI_API_KEY=your-openai-api-key
LLM_MONTHLY_LIMIT=500000

# === Business Days ===
# ERP_EXTRA_HOLIDAYS=2026-03-01,2026-05-05

# === Auto-Configuration ===
AUTO_CREATE_TABLES=true
AUTO_RUN_MIGRATIONS=true

# === Scheduler ===
SCHEDULER_TIMEZONE=Asia/Seoul
